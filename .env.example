# Convex Configuration
CONVEX_DEPLOYMENT=your-convex-deployment-url
EXPO_PUBLIC_CONVEX_URL=your-convex-url

# AI Configuration (OpenRouter)
# Single API key for all AI calls. Uses model fallback chain automatically.
# Free models tried in order: gemini-2.0-flash-exp → qwen2.5-7b → llama-3.2-3b → mistral-nemo
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key

# Email Configuration (Resend)
# Get key at: https://resend.com/api-keys
RESEND_API_KEY=your-resend-api-key

# Push Notifications (Expo)
# Get token at: https://expo.dev/notifications
EXPO_ACCESS_TOKEN=your-expo-access-token